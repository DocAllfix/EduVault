# === Database (BP §02.6) ===
# App-runtime connects as nexus_app (no DELETE/UPDATE on audit_log).
DATABASE_URL=postgresql://nexus_app:${POSTGRES_APP_PASSWORD}@postgres:5432/nexus
# Admin URL used by seed.py and migrations only.
DATABASE_ADMIN_URL=postgresql://nexus_admin:${POSTGRES_ADMIN_PASSWORD}@postgres:5432/nexus
# Generate with: openssl rand -base64 32
POSTGRES_ADMIN_PASSWORD=
POSTGRES_APP_PASSWORD=

# === External API keys ===
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
BRAVE_SEARCH_API_KEY=
# OPENAI_API_KEY removed in v3.0 (OPT-1): audio TTS via edge-tts, no key needed

# === JWT (BP §08.1 — SINGLE secret, token type in payload) ===
# Generate with: openssl rand -hex 64
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# === Runtime / CORS ===
# REI-13: domain not yet chosen. Use localhost in dev; the real domain
# will be set only at PHASE 7 (deploy).
APP_DOMAIN=<DOMAIN_TBD>
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
PIPELINE_TIMEOUT=1800
LLM_REQUEST_TIMEOUT=120
MAX_CONCURRENT_JOBS=1

# === TTS (OPT-1 v3.0 — edge-tts, no API key) ===
TTS_VOICE=it-IT-DiegoNeural

# === Seed (REI-13: keep <DOMAIN_TBD> until deploy) ===
ADMIN_BOOTSTRAP_EMAIL=admin@<DOMAIN_TBD>
# Generate with: openssl rand -base64 24
ADMIN_BOOTSTRAP_PASSWORD=

# === Branding ===
ORGANIZATION_NAME=corsi8108

# === Frontend (SWAP-1 v4.0: shadcn-admin local, no external repo) ===
NEXT_PUBLIC_API_URL=http://localhost:8000
