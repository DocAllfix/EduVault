# Nexus EduVault frontend — environment variables (Vite, prefix VITE_).
#
# Copy to `.env` for local dev. NEVER commit `.env` (gitignored).
# REI-13: domain is DA DECIDERE at deploy time — keep these values
# pointing at the local backend for dev; production overrides happen in
# `.env.production` (FASE 7).

# FastAPI backend base URL. Used by both REST client (`lib/api.ts`) and
# WebSocket client (`lib/ws.ts` derives ws://... from this).
# Trailing slash is stripped by the client.
VITE_API_URL=http://localhost:8000

# (legacy template var — keep empty, we don't use Clerk; REI-4)
VITE_CLERK_PUBLISHABLE_KEY=
